# ── VitalFix Environment Variables ──

# PSI Key Pool — comma-separated for round-robin rotation
# Add multiple keys to increase throughput & survive 429s
# Get keys at: https://console.cloud.google.com/apis/credentials
PSI_API_KEYS_POOL=your_key_1,your_key_2,your_key_3

# Legacy single key (fallback if PSI_API_KEYS_POOL is empty)
GOOGLE_PSI_API_KEY=your_single_key
